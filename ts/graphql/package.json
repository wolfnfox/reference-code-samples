{
  "name": "graphql",
  "version": "0.0.0",
  "description": "A reference example for a GraphQL API with Apollo Server, Prisma, and TypeScript.",
  "main": "src/main.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev src/main.ts",
    "start": "cross-env NODE_ENV=production tsx src/main.ts"
  },
  "keywords": [
    "graphql",
    "apollo",
    "prisma",
    "typescript"
  ],
  "author": "wolfnfox",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@prisma/client": "^6.17.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "22.13.14",
    "cross-env": "^10.1.0",
    "prisma": "^6.17.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "luxon": "^3.7.2"
  }
